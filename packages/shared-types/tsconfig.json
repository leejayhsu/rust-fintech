{
  "compilerOptions": {
    "lib": ["ES2022"],
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "composite": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
